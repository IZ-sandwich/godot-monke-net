[node name="OfflineBall" type="RigidBody3D" parent="Map" unique_id=1000010001]
editor_description = "Local-only ball — not networked. Each client runs an independent simulation, so it is intentionally non-interactive: collision_layer = 4 (OfflineProps, bit 3) and collision_mask = 1 (Environment only). Players do NOT collide with it, so a player walking through this ball cannot be pushed back by the local-only body — that bidirectional push would create a position desync against the server (which has no offline-ball collider for the server-player) and the resulting reconciliation would jerk the player. The ball still falls under gravity and rests on the floor; OfflineRigidbody3D keeps its state stable across client rollback."
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 5, 1, 5)
collision_layer = 4
physics_material_override = SubResource("PhysicsMaterial_ball")
linear_damp = 0.4
angular_damp = 0.8

[node name="MeshInstance3D" type="MeshInstance3D" parent="Map/OfflineBall" unique_id=1000010002]
mesh = SubResource("SphereMesh_orangeball")

[node name="CollisionShape3D" type="CollisionShape3D" parent="Map/OfflineBall" unique_id=1000010003]
shape = SubResource("SphereShape3D_orangeball")

