linear_damp = 0.4
angular_damp = 0.8

; VisualRoot is a regular (non-top_level) child of the body so Godot's
; SceneTreeFTI lerps it in lockstep with the body's other inherited children
; (CollisionShape3D's debug wireframe, labels, etc.) every render frame. The
; smoother writes Visual.GlobalPosition = body.GlobalPosition + offset; Godot
; internally computes the corresponding local Position relative to the body,
; so the mesh tracks the body's interpolated render-frame pose plus the
; (decaying) offset. With top_level=true the smoother's writes bypassed FTI's
; parent-chain interpolation, leaving the mesh stair-stepped at physics-tick
; rate while sibling children were rendered smoothly — visible as a
; mesh-vs-label oscillation every other render frame and as a 1–2 frame lag
; behind the body's debug wireframe.
[node name="VisualRoot" type="Node3D" parent="." unique_id=1700010006]

[node name="MeshInstance3D" type="MeshInstance3D" parent="VisualRoot" unique_id=1700010002]
mesh = SubResource("BoxMesh_cube")

[node name="CollisionShape3D" type="CollisionShape3D" parent="." unique_id=1700010003]
shape = SubResource("BoxShape3D_cube")

[node name="PredictionVisualSmoothing" type="Node3D" parent="." unique_id=1700010007 node_paths=PackedStringArray("Body", "Visual")]
script = ExtResource("4_smooth")
Body = NodePath("..")
Visual = NodePath("../VisualRoot")
metadata/_custom_type_script = "uid://rp5ifdkt35gg"

